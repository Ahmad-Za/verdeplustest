stead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[15645,15648],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":12,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useMemo, useEffect } from 'react';\r\nimport { type UserRole, MOCK_READINGS, SESSION_CARDS, getStatus, overallAQI, REGIONS } from '../data';\r\nimport { Sparkline } from '../components/Sparkline';\r\nimport { useI18n } from '../i18n';\r\nimport { supabase } from '../supabase';\r\n\r\ninterface DashboardProps {\r\n    role?: UserRole;\r\n    onNavigate: (page: string) => void;\r\n}\r\n\r\nexport default function DashboardPage({ role, onNavigate }: DashboardProps) {\r\n    const { t } = useI18n();\r\n    const [readings, setReadings] = useState(MOCK_READINGS);\r\n\r\n    useEffect(() => {\r\n        // Fetch initial data\r\n        const fetchReadings = async () => {\r\n            const { data, error } = await supabase.from('readings').select('*');\r\n            if (data && !error && data.length > 0) {\r\n                // Map DB rows back to frontend format\r\n                const newReadings = REGIONS.map((region, id) => {\r\n                    const row = data.find(d => d.region === region);\r\n                    return {\r\n                        id: id + 1,\r\n                        date: new Date().toISOString().split('T')[0], // Add missing date back for frontend typings\r\n                        region,\r\n                        ch4: row ? parseFloat(row.ch4) : 0,\r\n                        c3h8: row ? parseFloat(row.c3h8) : 0,\r\n                        h2: row ? parseFloat(row.h2) : 0\r\n                    };\r\n                });\r\n                setReadings(newReadings);\r\n            }\r\n        };\r\n\r\n        fetchReadings();\r\n\r\n        // Subscribe to real-time changes\r\n        const channel = supabase\r\n            .channel('public:readings')\r\n            .on('postgres_changes', { event: '*', schema: 'public', table: 'readings' }, (payload) => {\r\n                const updatedRow = payload.new as any; // Type assertion for payload.new\r\n                setReadings(prev => prev.map(r =>\r\n                    r.region === updatedRow.region ? {\r\n                        ...r,\r\n                        ch4: parseFloat(updatedRow.ch4),\r\n                        c3h8: parseFloat(updatedRow.c3h8),\r\n                        h2: parseFloat(updatedRow.h2),\r\n                    } : r\r\n                ));\r\n            })\r\n            .subscribe();\r\n\r\n        return () => {\r\n            supabase.removeChannel(channel);\r\n        };\r\n    }, []);\r\n\r\n    const aqi = overallAQI(readings);\r\n    const aqiStatus = aqi < 40 ? 'normal' : aqi < 70 ? 'warning' : 'danger';\r\n    const aqiColor = aqiStatus === 'normal' ? '#00FF80' : aqiStatus === 'warning' ? '#FFB84C' : '#FF4C4C';\r\n    const aqiLabel = aqiStatus === 'normal' ? t('insights.normal') : aqiStatus === 'warning' ? t('insights.warning') : t('insights.danger');\r\n    const aqiTip = aqiStatus === 'normal' ? t('health.good') : aqiStatus === 'warning' ? t('health.moderate') : t('health.hazardous');\r\n\r\n    const topZones = useMemo(() =>\r\n        [...readings]\r\n            .sort((a, b) => (b.ch4 + b.c3h8 + b.h2) - (a.ch4 + a.c3h8 + a.h2))\r\n            .slice(0, 3),\r\n        [readings]\r\n    );\r\n\r\n    const avgGas = useMemo(() => {\r\n        const len = readings.length || 1;\r\n        return {\r\n            ch4: readings.reduce((a: any, b: any) => a + b.ch4, 0) / len,\r\n            c3h8: readings.reduce((a: any, b: any) => a + b.c3h8, 0) / len,\r\n            h2: readings.reduce((a: any, b: any) => a + b.h2, 0) / len\r\n        };\r\n    }, [readings]);\r\n\r\n    const gasCards = [\r\n        { key: 'ch4', label: 'в”ҳГ в”ҳГЁв•ӘВҪв•ӘВәв”ҳГҘ (CHО“Г©ГӨ)', unit: 'ppm', val: avgGas.ch4, tooltip: t('tooltip.ch4') },\r\n        { key: 'c3h8', label: 'в•ӘВҝв•Әв–’в”ҳГӘв•ӘВҝв•ӘВәв”ҳГҘ (CО“Г©ГўHО“Г©ГӘ)', unit: 'ppm', val: avgGas.c3h8, tooltip: t('tooltip.c3h8') },\r\n        { key: 'h2', label: 'в”ҳГ§в”ҳГЁв•ӘВ»в•Әв–’в”ҳГӘв•ӘВјв”ҳГЁв”ҳГҘ (HО“Г©Г©)', unit: 'ppm', val: avgGas.h2, tooltip: t('tooltip.h2') },\r\n    ];\r\n\r\n    const [activeTag, setActiveTag] = useState<string | null>(null);\r\n    const tags = ['в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬', 'в•Әв•–в•ӘВәв”ҳГ©в•ӘвҢҗ в”ҳГ в•ӘВ¬в•ӘВјв•ӘВ»в•ӘВ»в•ӘвҢҗ', 'в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯв•ӘвҢҗ в•Әв•Јв”ҳГ в•ӘВәв•Әв–’в•ӘвҢҗ', 'в•ӘВәв”ҳГҘв•ӘВҝв•Әв•Јв•ӘВәв•ӘВҪв•ӘВәв•ӘВ¬'];\r\n    const filteredSessions = activeTag && activeTag !== 'в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬'\r\n        ? SESSION_CARDS.filter(s => s.tag === activeTag)\r\n        : SESSION_CARDS;\r\n\r\n    return (\r\n        <div className=\"p-6 max-w-7xl mx-auto animate-fade-in\">\r\n            <h2 className=\"text-2xl font-bold mb-6\">{t('insights.title')}</h2>\r\n\r\n            {/* Bento Grid */}\r\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-5 mb-8\">\r\n\r\n                {/* Hero AQI Card */}\r\n                <div\r\n                    className={`md:col-span-2 glass-card p-8 flex flex-col justify-between min-h-[200px] transition-all duration-500 hover:scale-[1.01] ${aqiStatus === 'warning' ? 'shadow-[0_0_30px_rgba(255,184,76,0.1)] border-yellow-500/20' :\r\n                        aqiStatus === 'danger' ? 'shadow-[0_0_40px_rgba(255,76,76,0.2)] border-red-500/30' : ''\r\n                        }`}\r\n                >\r\n                    <div>\r\n                        <p className=\"text-vp-muted text-sm mb-1\">{t('insights.aqi')}</p>\r\n                        <p className=\"text-xs text-vp-muted\">{t('insights.campus')}</p>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-2 mt-2\">\r\n                        <span className=\"relative flex h-3 w-3\">\r\n                            <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-vp-green opacity-75\"></span>\r\n                            <span className=\"relative inline-flex rounded-full h-3 w-3 bg-vp-green\"></span>\r\n                        </span>\r\n                        <span className=\"text-xs text-vp-green font-medium\">в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’ (Supabase Realtime)</span>\r\n                    </div>\r\n                    <div className=\"flex items-end gap-6 mt-6\">\r\n                        <div>\r\n                            <p className=\"font-extrabold leading-none mb-2\" style={{ fontSize: '6rem', color: aqiColor, textShadow: `0 0 30px ${aqiColor}55` }}>\r\n                                {aqi}\r\n                            </p>\r\n                            <span className={`status-badge-${aqiStatus}`}>{aqiLabel}</span>\r\n                        </div>\r\n                        <div className=\"pb-1\">\r\n                            <p className=\"text-vp-muted text-sm pb-3 leading-relaxed\">\r\n                                в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГ в•ӘГұв•Әв”Өв•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГӘв•ӘВҪ в•ӘВәв”ҳГӨв•Әв•‘в•ӘВәв•Әв–“в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВҪв”ҳГӨв•ӘВәв•ӘВҪв•ӘвҢҗ<br />в•Әв•Јв•ӘВҝв•Әв–’ 10 в”ҳГ в”ҳГҘв•ӘВәв•Әв•–в”ҳГ© в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв•Әв–’в”ҳГ  в•ӘВәв”ҳГӨв•ӘВјв•ӘВәв”ҳГ в•Әв•Јв”ҳГЁ\r\n                            </p>\r\n                            <div className=\"inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2 mt-2\">\r\n                                <span className=\"text-sm font-medium text-white/90\">{aqiTip}</span>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                {/* Top Zones */}\r\n                <div className=\"glass-card p-6 transition-transform hover:-translate-y-1 duration-300\">\r\n                    <div className=\"flex items-center gap-2 mb-4\">\r\n                        <span className=\"w-1.5 h-4 bg-orange-500 rounded-full\"></span>\r\n                        <p className=\"text-sm font-semibold text-vp-muted\">{t('insights.worst')}</p>\r\n                    </div>\r\n                    <div className=\"space-y-3\">\r\n                        {topZones.map((z: any, i: number) => {\r\n                            const total = z.ch4 + z.c3h8 + z.h2;\r\n                            const s = getStatus('ch4', z.ch4);\r\n                            return (\r\n                                <div key={z.id} className=\"flex items-center justify-between\">\r\n                                    <div className=\"flex items-center gap-2\">\r\n                                        <span className=\"text-vp-muted font-mono text-xs\">#{i + 1}</span>\r\n                                        <span className=\"text-sm font-medium\">{z.region}</span>\r\n                                    </div>\r\n                                    <div className=\"flex items-center gap-2\">\r\n                                        <span className=\"font-mono text-sm\">{total.toFixed(1)}</span>\r\n                                        <span className={`status-badge-${s === 'danger' ? 'danger' : s === 'warning' ? 'warning' : 'normal'}`}>\r\n                                            {s === 'normal' ? 'О“ГҘГҙ' : s === 'warning' ? 'О“ГҘГҰ' : 'О“ГңГЎ'}\r\n                                        </span>\r\n                                    </div>\r\n                                </div>\r\n                            );\r\n                        })}\r\n                    </div>\r\n                </div>\r\n\r\n                {/* Gas Micro-cards */}\r\n                {gasCards.map(g => {\r\n                    const s = getStatus(g.key, g.val);\r\n                    const cardColor = s === 'normal' ? '#00FF80' : s === 'warning' ? '#FFB84C' : '#FF4C4C';\r\n                    return (\r\n                        <div key={g.key} className={`glass-card p-5 transition-all duration-300 group ${s !== 'normal' ? 'border-t-2 hover:-translate-y-1' : 'hover:-translate-y-1'}`} style={{ borderTopColor: s !== 'normal' ? cardColor : 'transparent', boxShadow: s === 'danger' ? '0 10px 30px -10px rgba(255,76,76,0.1)' : '' }}>\r\n                            <div className=\"flex items-start justify-between mb-3\">\r\n                                <div>\r\n                                    <div className=\"flex items-center gap-1.5 group/tooltip relative w-fit mt-1 mb-1\">\r\n                                        <p className=\"text-vp-muted text-xs transition-colors group-hover:text-white cursor-help border-b border-dashed border-white/20 pb-0.5\">{g.label}</p>\r\n                                        {/* Tooltip Hover */}\r\n                                        <div className=\"absolute bottom-full left-0 mb-2 w-48 p-2 bg-black text-xs text-white rounded-lg opacity-0 pointer-events-none group-hover/tooltip:opacity-100 transition-opacity z-20 border border-white/10 shadow-xl\">\r\n                                            {g.tooltip}\r\n                                        </div>\r\n                                    </div>\r\n                                    <p className=\"text-3xl font-bold mt-1\" style={{ color: cardColor }}>\r\n                                        {g.val.toFixed(1)}\r\n                                        <span className=\"text-sm text-vp-muted font-normal mr-1\">{g.unit}</span>\r\n                                    </p>\r\n                                </div>\r\n                                <span className={`status-badge-${s === 'danger' ? 'danger' : s === 'warning' ? 'warning' : 'normal'}`}>\r\n                                    {s === 'normal' ? t('level.good') : s === 'warning' ? t('level.moderate') : t('level.danger')}\r\n                                </span>\r\n                            </div>\r\n                            <Sparkline gas={g.key as any} color={cardColor} />\r\n                        </div>\r\n                    );\r\n                })}\r\n\r\n                {/* Gamification О“ГҮГ¶ Leaderboard */}\r\n                <div className=\"glass-card p-6 transition-transform hover:-translate-y-1 duration-300\">\r\n                    <div className=\"flex items-center gap-2 mb-4\">\r\n                        <span className=\"w-1.5 h-4 bg-yellow-400 rounded-full\"></span>\r\n                        <p className=\"text-sm font-semibold\">в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁ в•ӘВәв”ҳГӨв•ӘГәв”ҳГ©в•Әв”Ӯв•ӘВәв”ҳГ </p>\r\n                    </div>\r\n                    <div className=\"space-y-3\">\r\n                        {[\r\n                            { name: 'в•ӘВәв”ҳГӨв”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв”ҳГӨв”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬в”ҳГЁв•ӘвҢҗ', pts: 920, medal: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘВәв”ҳГӨв•ӘГәв”ҳГӘв”ҳГӨ' },\r\n                            { name: 'в•ӘВәв”ҳГӨв”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв”ҳГ в•ӘВәв•Әв–’в”ҳГЁв•ӘвҢҗ', pts: 880, medal: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘВәв”ҳГӨв•ӘВҪв•ӘВәв”ҳГҘв”ҳГЁ' },\r\n                            { name: 'в•ӘВәв”ҳГӨв”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГўв”ҳГ§в•Әв–’в•ӘВҝв•ӘВәв•ӘВӘв”ҳГЁв•ӘвҢҗ', pts: 840, medal: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘВәв”ҳГӨв•ӘВҪв•ӘВәв”ҳГӨв•ӘВҪ' },\r\n                        ].map((d, i) => (\r\n                            <div key={d.name} className=\"flex items-center justify-between p-2 rounded-lg hover:bg-white/5 transition-colors\">\r\n                                <div className=\"flex items-center gap-2\">\r\n                                    <span className={`text-xs font-bold px-2 py-0.5 rounded ${i === 0 ? 'bg-yellow-500/20 text-yellow-500' : i === 1 ? 'bg-gray-400/20 text-gray-400' : 'bg-amber-700/20 text-amber-600'}`}>\r\n                                        {i + 1}\r\n                                    </span>\r\n                                    <span className=\"text-sm\">{d.name}</span>\r\n                                </div>\r\n                                <span className=\"text-vp-green font-mono text-sm\">{d.pts} pts</span>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                    <p className=\"text-xs text-vp-muted mt-4 border-t border-white/5 pt-4\">\r\n                        в•ӘВәв”ҳГӨв”ҳГўв”ҳГӨв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГЁ в•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘГәв”ҳГ©в”ҳГӨ в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬ в•ӘВ¬в”ҳГӨв”ҳГӘв•ӘВҪ в•ӘВ¬в•ӘВЎв•Әв•Ўв”ҳГӨ в•Әв•Јв”ҳГӨв”ҳГ« в”ҳГҘв”ҳГ©в•ӘВәв•Әв•– в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ»в•ӘВәв”ҳГ в•ӘвҢҗ в•ӘГәв•Әв•Јв”ҳГӨв”ҳГ«.\r\n                    </p>\r\n                </div>\r\n\r\n            </div>\r\n\r\n            {/* Historical Dashboard navigation */}\r\n            <div\r\n                onClick={() => onNavigate('logs')}\r\n                className=\"glass-card mb-8 p-6 flex flex-col md:flex-row items-center justify-between gap-6 hover:bg-white/5 hover:border-vp-green/30 transition-all cursor-pointer group relative overflow-hidden\"\r\n            >\r\n                <div className=\"absolute -right-16 -top-16 w-32 h-32 bg-vp-green/10 rounded-full blur-2xl group-hover:bg-vp-green/20 transition-colors\"></div>\r\n                <div className=\"flex items-center gap-5 z-10 w-full md:w-auto\">\r\n                    <div className=\"w-16 h-16 bg-gradient-to-br from-vp-green/20 to-teal-500/20 text-vp-green rounded-2xl flex items-center justify-center backdrop-blur-md border border-vp-green/30 group-hover:scale-110 transition-transform\">\r\n                        <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"></polyline></svg>\r\n                    </div>\r\n                    <div>\r\n                        <h3 className=\"text-xl font-bold mb-1 text-white group-hover:text-vp-green transition-colors\">{t('insights.logs_title')}</h3>\r\n                        <p className=\"text-sm text-vp-muted\">{t('insights.logs_desc')}</p>\r\n                    </div>\r\n                </div>\r\n                <button className=\"neon-btn px-6 py-2.5 whitespace-nowrap hidden md:block z-10\">{t('insights.logs_btn')}</button>\r\n            </div>\r\n\r\n            {/* Historical Data Table */}\r\n            <div className=\"glass-card p-6 mb-8 transition-transform hover:scale-[1.01] duration-300\">\r\n                <div className=\"flex items-center gap-2 mb-4\">\r\n                    <span className=\"w-1.5 h-4 bg-teal-500 rounded-full\"></span>\r\n                    <p className=\"text-lg font-semibold\">{t('insights.table_title')}</p>\r\n                </div>\r\n                <div className=\"overflow-x-auto\">\r\n                    <table className=\"w-full text-sm\">\r\n                        <thead className={1 === 1 ? 'text-left' : 'text-right'}>\r\n                            <tr className=\"text-vp-muted border-b border-white/5\">\r\n                                <th className=\"pb-3 font-medium\">{t('insights.region')}</th>\r\n                                <th className=\"pb-3 font-medium\">CHО“Г©ГӨ (ppm)</th>\r\n                                <th className=\"pb-3 font-medium\">CО“Г©ГўHО“Г©ГӘ (ppm)</th>\r\n                                <th className=\"pb-3 font-medium\">HО“Г©Г© (ppm)</th>\r\n                                <th className=\"pb-3 font-medium\">{t('insights.status')}</th>\r\n                            </tr>\r\n                        </thead>\r\n                        <tbody className=\"divide-y divide-white/5\">\r\n                            {readings.map((r: any) => {\r\n                                const s = getStatus('ch4', r.ch4);\r\n              